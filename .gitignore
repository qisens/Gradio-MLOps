# 1. 모든 파일 / 폴더 무시
*

# 2. gitignore 자체는 추적
!.gitignore
!app.py
!requirements.txt

# 3. 허용할 최상위 폴더들
!core/
!json/
!ui/

# 4. 허용한 폴더 안의 내용도 추적
!core/**
!json/**
!ui/**

#===========================================

# Python
__pycache__/
*.pyc
*.pyo

# IDE
.idea/
.vscode/

# Gradio / temp
.gradio/
*.tmp

# Logs
*.log

# Env / secrets
.env
.env.*

# Model artifacts
runs/
weights/
*.pt
*.onnx
*.engine

# Results (보통 산출물은 제외)
inf_results/

# Temp generated
temp_generated.json

# OS
.DS_Store
